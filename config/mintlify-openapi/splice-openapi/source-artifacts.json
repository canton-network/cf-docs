{
  "source": "Splice OpenAPI specs from published decentralized-canton-sync release bundles",
  "release_repo": "digital-asset/decentralized-canton-sync",
  "tag_regex": "^v(?P<version>0\\.[0-9]+\\.[0-9]+)$",
  "min_version": "0.5.10",
  "publish_version": "0.5.18",
  "asset_template": "{version}_openapi.tar.gz",
  "nav_dropdown": "API Reference",
  "top_level_group_label": "Splice APIs",
  "insert_after_group": "Wallet Gateway",
  "managed_openapi_root": "openapi/splice",
  "enabled_nav_specs": [
    "scan.yaml",
    "scan-stream-server.yaml",
    "wallet-external.yaml",
    "ans-external.yaml",
    "scan-proxy.yaml",
    "token-metadata-v1.yaml",
    "transfer-instruction-v1.yaml",
    "allocation-v1.yaml",
    "allocation-instruction-v1.yaml"
  ],
  "legacy_cleanup_paths": [
    "reference/splice-scan-openapi"
  ],
  "families": [
    {
      "group": "Scan APIs",
      "specs": [
        {
          "filename": "scan.yaml",
          "nav_label": "Scan API",
          "source": "openapi/splice/scan/scan.yaml",
          "directory": "reference/splice-scan-api"
        },
        {
          "filename": "scan-stream-server.yaml",
          "nav_label": "Scan Streaming API",
          "source": "openapi/splice/scan/scan-stream-server.yaml",
          "directory": "reference/splice-scan-streaming-api"
        }
      ]
    },
    {
      "group": "Validator APIs",
      "specs": [
        {
          "filename": "wallet-external.yaml",
          "nav_label": "Wallet API (External)",
          "source": "openapi/splice/validator/wallet-external.yaml",
          "directory": "reference/splice-wallet-api-external"
        },
        {
          "filename": "wallet-internal.yaml",
          "nav_label": "Wallet API (Internal)",
          "source": "openapi/splice/validator/wallet-internal.yaml",
          "directory": "reference/splice-wallet-api-internal"
        },
        {
          "filename": "validator-internal.yaml",
          "nav_label": "Validator API (Internal)",
          "source": "openapi/splice/validator/validator-internal.yaml",
          "directory": "reference/splice-validator-api-internal"
        },
        {
          "filename": "ans-external.yaml",
          "nav_label": "ANS API",
          "source": "openapi/splice/validator/ans-external.yaml",
          "directory": "reference/splice-ans-api"
        },
        {
          "filename": "scan-proxy.yaml",
          "nav_label": "Scan Proxy API",
          "source": "openapi/splice/validator/scan-proxy.yaml",
          "directory": "reference/splice-scan-proxy-api"
        }
      ]
    },
    {
      "group": "Token Standard APIs",
      "flatten_openapi_nav": true,
      "specs": [
        {
          "filename": "token-metadata-v1.yaml",
          "nav_label": "Token Metadata Service",
          "source": "openapi/splice/token-standard/token-metadata-v1.yaml",
          "directory": "reference/splice-token-metadata-service"
        },
        {
          "filename": "transfer-instruction-v1.yaml",
          "nav_label": "Transfer Instruction API",
          "source": "openapi/splice/token-standard/transfer-instruction-v1.yaml",
          "directory": "reference/splice-transfer-instruction-api"
        },
        {
          "filename": "allocation-v1.yaml",
          "nav_label": "Allocation API",
          "source": "openapi/splice/token-standard/allocation-v1.yaml",
          "directory": "reference/splice-allocation-api"
        },
        {
          "filename": "allocation-instruction-v1.yaml",
          "nav_label": "Allocation Instruction API",
          "source": "openapi/splice/token-standard/allocation-instruction-v1.yaml",
          "directory": "reference/splice-allocation-instruction-api"
        }
      ]
    }
  ]
}
