{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Canton Network Docs",
  "colors": {
    "primary": "#734BE2",
    "light": "#A985FF",
    "dark": "#5C3DB8"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 700
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/images/canton-logo-dark.svg",
    "dark": "/images/canton-logo-white.svg",
    "href": "/landing/landing"
  },
  "appearance": {
    "default": "system"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navigation": {
    "dropdowns": [
      {
        "dropdown": "SDKs and Tools",
        "versions": [
          {
            "version": "MainNet",
            "groups": [
              {
                "group": "Overview",
                "pages": [
                  "docs-main/sdks-tools/overview"
                ]
              },
              {
                "group": "SDKs",
                "pages": [
                  "docs-main/sdks-tools/sdks/daml-sdk",
                  "docs-main/sdks-tools/sdks/exchange-sdk"
                ]
              },
              {
                "group": "Language Bindings",
                "pages": [
                  "docs-main/sdks-tools/language-bindings/typescript",
                  "docs-main/sdks-tools/language-bindings/java",
                  "docs-main/sdks-tools/language-bindings/scala",
                  "docs-main/sdks-tools/language-bindings/community"
                ]
              },
              {
                "group": "CLI Tools",
                "pages": [
                  "docs-main/sdks-tools/cli-tools/canton-console",
                  "docs-main/sdks-tools/cli-tools/daml-script"
                ]
              },
              {
                "group": "Development Tools",
                "pages": [
                  "docs-main/sdks-tools/development-tools/daml-studio",
                  "docs-main/sdks-tools/development-tools/localnet",
                  "docs-main/sdks-tools/development-tools/sandbox",
                  "docs-main/sdks-tools/development-tools/pqs"
                ]
              },
              {
                "group": "Reference Projects",
                "pages": [
                  "docs-main/sdks-tools/reference-projects/cn-quickstart",
                  "docs-main/sdks-tools/reference-projects/splice-reference-apps"
                ]
              }
            ]
          }
        ],
        "icon": "wrench"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/CantonNetwork",
      "github": "https://github.com/digital-asset",
      "linkedin": "https://www.linkedin.com/company/canton-network/",
      "discord": "https://discord.gg/canton",
      "telegram": "https://t.me/CantonNetwork1"
    },
    "links": [
      {
        "header": "Legal",
        "items": [
          {
            "label": "Documentation License (CC-BY-4.0)",
            "href": "https://creativecommons.org/licenses/by/4.0/"
          },
          {
            "label": "Code License (Apache-2.0)",
            "href": "https://www.apache.org/licenses/LICENSE-2.0"
          }
        ]
      }
    ]
  }
}
