{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "DAML Docs",
  "fonts": {
    "family": "Lato"
  },
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "products": [],
    "global": {
      "versions": [
      {
        "version": "DevNet",
        "href": "/devnet"
      },
      {
        "version": "TestNet",
        "href": "/testnet"
      },
      {
        "version": "MainNet",
        "href": "/mainnet"
      },
      {
        "version": "Prerelease (3.5.x)",
        "href": "/prerelease"
      }
      ],
      "tabs": [
        { "tab": "Overview",
          "href": "/devnet/overview",
          "versions": [
            {
              "version": "DevNet",
              "default": true,
              "groups": [
                {
                  "group": "Introduction",
                  "pages": [
                    "devnet/overview/overview",
                    "devnet/overview/overview/multiparty-application-intro",
                    "devnet/overview/overview/canton",
                    "devnet/overview/overview/featured-use-cases"
                  ]
                }
              ]
            },
            {
              "version": "TestNet",
              "groups": [
                {
                  "group": "Introduction",
                  "pages": [
                    "testnet/overview/overview",
                    "testnet/overview/overview/multiparty-application-intro",
                    "testnet/overview/overview/canton",
                    "testnet/overview/overview/featured-use-cases"
                  ]
                }
              ]
            },
            {
              "version": "MainNet",
              "groups": [
                {
                  "group": "Introduction",
                  "pages": [
                    "mainnet/overview/overview",
                    "mainnet/overview/overview/multiparty-application-intro",
                    "mainnet/overview/overview/canton",
                    "mainnet/overview/overview/featured-use-cases"
                  ]
                }
              ]
            },
            {
              "version": "Prerelease (3.5.x)",
              "groups": [
                {
                  "group": "Introduction",
                  "pages": [
                    "prerelease/overview/overview",
                    "prerelease/overview/overview/multiparty-application-intro",
                    "prerelease/overview/overview/canton",
                    "prerelease/overview/overview/featured-use-cases"
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "logo": {
    "light": "assets/logo.svg",
    "dark": "assets/logo.svg"
  },
  "navbar": {
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/mintlify",
      "github": "https://github.com/mintlify",
      "linkedin": "https://linkedin.com/company/mintlify"
    }
  }
}
